# OpenAI API Key - Obter em https://platform.openai.com/
OPENAI_API_KEY=sk-your-key-here

# Modelo da OpenAI (padrão gpt-4o)
OPENAI_MODEL=gpt-4o

# Caminho do banco de dados (relativo ou absoluto)
# No Docker/Easypanel recomenda-se usar caminho absoluto: /app/data/app.db
DB_PATH=/app/data/app.db
DATABASE_URL=sqlite:////app/data/app.db

# Configurações de Debug e Métricas
ENABLE_DIAGNOSTICS=1
DEBUG=0
